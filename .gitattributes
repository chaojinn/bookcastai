# Normalize all text files to LF in the repo, check out as-is
* text=auto eol=lf

# Force these to always be LF (scripts run on Linux/WSL)
*.py    text eol=lf
*.sh    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf

# Binary files — never touch line endings
*.png   binary
*.jpg   binary
*.wav   binary
*.mp3   binary
*.pt    binary
*.safetensors binary
